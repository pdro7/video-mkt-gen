{
  "name": "video-gen",
  "version": "0.1.0",
  "description": "Genera videos promocionales con avatares a partir de un guion: planea escenas (Claude), genera imágenes con referencia del avatar (Nano Banana) y crea videos por escena (HeyGen).",
  "type": "module",
  "private": true,
  "bin": {
    "video-gen": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli/index.ts",
    "generate": "tsx src/cli/index.ts generate",
    "start": "node dist/cli/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@google/genai": "^1.30.0",
    "commander": "^14.0.1",
    "dotenv": "^17.2.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
