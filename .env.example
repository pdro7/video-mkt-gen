# Copia este archivo a .env y completa con tus credenciales.
# Cada cliente (en el producto final) usa sus propias claves aquí.

# LLM que genera el spec de producción (Claude / Anthropic)
ANTHROPIC_API_KEY=

# Generación de video por escena (HeyGen, Avatar IV).
# La voz la maneja HeyGen vía voice_id (puede ser una voz ElevenLabs conectada en HeyGen).
HEYGEN_API_KEY=

# Generación de base_images por API (opcional; etapa posterior). Ya la tienes configurada.
GOOGLE_API_KEY=   # Nano Banana / Gemini 2.5 Flash Image

# Escenas dinámicas (avatar en movimiento): voice changer con ElevenLabs (permiso speech_to_speech).
ELEVENLABS_API_KEY=

# --- Opcionales ---
# FAL_KEY=            # motor dinámico Veo vía fal.ai (config.video.dynamic.provider="fal"); cuota aparte
# OPENAI_API_KEY=
# KIE_API_KEY=
